# App Configuration
NODE_ENV="development"
APP_PORT=3000
DEBUG_PORT=9229

# Maximum medication lifecycle candidates processed by each five-minute run.
MEDICATION_LIFECYCLE_RECONCILIATION_LIMIT=100

# Application Database Configuration
# Use a complete PostgreSQL connection string. Docker Compose passes this value
# through unchanged; hosted databases must be reachable from the app container.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Database Seeding (Docker only)
# SEED_ON_EMPTY=true - Seed database if empty (recommended for development)
# SEED_DATABASE=true - Always run seed on startup (use with caution)
SEED_ON_EMPTY=true
SEED_DATABASE=false

# Redis Configuration
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# Background execution
# Enable these only on a persistent worker/container. Vercel uses HTTP Cron
# endpoints and keeps both disabled in Dockerfile.vercel.
ENABLE_QUEUE_WORKER=false
ENABLE_IN_PROCESS_CRON=false

# Vercel sends this value as: Authorization: Bearer <CRON_SECRET>.
# Use a random value of at least 16 characters in every production environment.
CRON_SECRET=

# CORS
CORS_ORIGIN="http://localhost:3000"

# CLERK
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Cloudflare R2 Storage (S3-compatible)
# All four values are required together to enable R2; leave them empty to use local storage.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
# Optional public read domain; URLs become public bearer URLs after issuance.
R2_PUBLIC_DOMAIN=

# Local Storage (fallback when R2 is not configured)
UPLOAD_DIR="./uploads"
BASE_URL="http://localhost:3000"
