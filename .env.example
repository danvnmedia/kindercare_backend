# App Configuration
NODE_ENV="development"
APP_PORT=3000
DEBUG_PORT=9229

# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/kindercare?schema=public"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="kindercare"
POSTGRES_PORT=5432

# Database Seeding (Docker only)
# SEED_ON_EMPTY=true - Seed database if empty (recommended for development)
# SEED_DATABASE=true - Always run seed on startup (use with caution)
SEED_ON_EMPTY=true
SEED_DATABASE=false

# Redis Configuration
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# CORS
CORS_ORIGIN="http://localhost:3000"

# CLERK
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Cloudflare R2 Storage (S3-compatible)
# Leave empty to use local storage
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
# Optional: Public domain for direct file access (faster, no presigned URL needed for downloads)
R2_PUBLIC_DOMAIN=

# Local Storage (fallback when R2 is not configured)
UPLOAD_DIR="./uploads"
BASE_URL="http://localhost:3000"

# File upload / R2 storage
# Required together to enable Cloudflare R2 storage
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=
# Optional public read domain; URLs become public bearer URLs after issuance
R2_PUBLIC_DOMAIN=
