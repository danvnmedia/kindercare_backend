# ==============================================================================
# KINDERCARE BACKEND - HUONG DAN BIEN MOI TRUONG
# ==============================================================================
# File nay chi la mau va duoc phep commit. KHONG dien secret that vao file nay.
# File `.env` da duoc .gitignore loai tru khoi Git.
#
# Chay local:
#   PowerShell: Copy-Item .env.example .env
#   macOS/Linux: cp .env.example .env
# Sau do thay cac gia tri can thiet trong `.env` va chay `npm run start:dev`.
#
# Trien khai Vercel:
#   1. Vao Vercel > Project > Settings > Environment Variables.
#   2. Them cac bien duoc danh dau [VERCEL: REQUIRED] cho Production.
#   3. Them bien cho Preview rieng neu co deploy preview. Khong dung chung
#      database/Clerk production cho Preview neu khong that su can thiet.
#   4. Danh dau DATABASE_URL, CLERK_SECRET_KEY, R2 credentials va CRON_SECRET
#      la Sensitive.
#   5. Redeploy sau moi lan them/sua env. Env moi khong ap dung cho deployment cu.
#
# Tai lieu:
#   Vercel env: https://vercel.com/docs/environment-variables
#   Vercel cron secret: https://vercel.com/docs/cron-jobs/manage-cron-jobs
# ==============================================================================

# ----------------------------------------------------------------------------
# APP RUNTIME
# ----------------------------------------------------------------------------
# Local: development. Vercel production: production.
# Dockerfile.vercel da dat NODE_ENV=production, nhung van nen khai bao ro tren
# Vercel de cau hinh de kiem tra.
# [VERCEL: REQUIRED]
NODE_ENV="development"

# Chi dung cho local/Docker Compose. Vercel tu cap bien PORT va ung dung se doc
# PORT truoc APP_PORT, vi vay KHONG them APP_PORT hoac PORT vao Vercel.
APP_PORT=3000
DEBUG_PORT=9229

# So medication lifecycle records toi da xu ly trong moi lan chay 5 phut.
# Tuy chon; mac dinh cua ung dung la 100. Tang gia tri can theo doi timeout/tai DB.
MEDICATION_LIFECYCLE_RECONCILIATION_LIMIT=100

# ----------------------------------------------------------------------------
# POSTGRESQL / PRISMA
# ----------------------------------------------------------------------------
# Cach tao va lay DATABASE_URL:
#   1. Tao PostgreSQL tren nha cung cap managed (Prisma Postgres, Neon, Supabase,
#      Railway, Render...) hoac chay local bang `docker-compose.db.yml`.
#   2. Trong dashboard nha cung cap, mo Connect/Connection string va copy URI
#      PostgreSQL day du.
#   3. Vercel runtime nen dung URL qua connection pooler va gioi han connection
#      thap. GitHub Actions `prisma migrate deploy` nen dung URL direct/migration-
#      safe cua cung database.
#   4. URI production thuong can `sslmode=require`. Ky tu dac biet trong username
#      hoac password phai duoc percent-encode.
#
# Dinh dang:
#   postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# Prisma reference: https://www.prisma.io/docs/orm/reference/connection-urls
#
# Gia tri ben duoi khop voi PostgreSQL local mac dinh trong docker-compose.db.yml.
# Tren Vercel, thay no bang pooled URL cua database production.
# [VERCEL: REQUIRED, SENSITIVE]
DATABASE_URL="postgresql://postgres:password@localhost:5432/kindercare?schema=public"

# Chi dung de tuy chinh PostgreSQL local trong docker-compose.db.yml. Ung dung
# khong doc truc tiep cac bien POSTGRES_* nay.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="kindercare"
POSTGRES_PORT=5432

# Seed chi danh cho development/container local.
# Production/Vercel: giu ca hai la false (Vercel khong seed luc startup).
SEED_ON_EMPTY=true
SEED_DATABASE=false

# ----------------------------------------------------------------------------
# REDIS / BULL QUEUE
# ----------------------------------------------------------------------------
# Vercel Container khong chay Bull worker lau dai, nen giu
# ENABLE_QUEUE_WORKER=false. Khi false, khong can cau hinh Redis tren Vercel.
# Chi bat true tren mot persistent worker/container rieng; khi do REDIS_HOST la
# bat buoc va nen dung TLS/credentials theo nha cung cap Redis.
ENABLE_QUEUE_WORKER=false
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# NestJS cron trong process chi phu hop persistent container. Vercel dung HTTP
# Cron khai bao trong vercel.json, nen luon giu false tren Vercel.
ENABLE_IN_PROCESS_CRON=false

# ----------------------------------------------------------------------------
# VERCEL CRON
# ----------------------------------------------------------------------------
# Tao chuoi ngau nhien it nhat 16 ky tu (khuyen nghi 32 bytes):
#   PowerShell:
#   [Convert]::ToHexString([Security.Cryptography.RandomNumberGenerator]::GetBytes(32)).ToLower()
#   macOS/Linux co OpenSSL:
#   openssl rand -hex 32
#
# Dat CHINH XAC ten CRON_SECRET tren Vercel. Vercel tu gui header:
#   Authorization: Bearer <CRON_SECRET>
# Khong dung chung secret nay voi Clerk, database hoac R2.
# [VERCEL: REQUIRED, SENSITIVE]
CRON_SECRET=""

# ----------------------------------------------------------------------------
# CORS / PUBLIC BACKEND URL
# ----------------------------------------------------------------------------
# Danh sach origin frontend CHINH XAC, phan tach bang dau phay.
# Chi ghi scheme + hostname + port; khong them path va nen bo dau `/` cuoi.
#
# Local vi du:
#   http://localhost:3000
# Production vi du:
#   https://kindercare-frontend.vercel.app,https://app.example.com
#
# Moi Preview frontend co domain dong; neu can Preview, nen cau hinh origin/domain
# preview rieng thay vi mo CORS bang `*`.
# [VERCEL: REQUIRED]
CORS_ORIGIN="http://localhost:3000"

# URL public cua backend, khong co dau `/` cuoi.
# Production hien tai: https://kindercare-backend.vercel.app
# [VERCEL: REQUIRED]
BASE_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# CLERK AUTHENTICATION
# ----------------------------------------------------------------------------
# Cach tao va lay key:
#   1. Vao https://dashboard.clerk.com va tao/chon application Kindercare.
#   2. Chon dung instance Development hoac Production o goc tren dashboard.
#   3. Vao Configure > API keys (hoac trang API Keys) va copy hai key.
#   4. Local dung pk_test_... + sk_test_.... Production dung pk_live_... +
#      sk_live_... cua CUNG MOT Clerk production instance.
#   5. Frontend cung phai dung Publishable Key cua cung instance.
#
# CLERK_PUBLISHABLE_KEY co the cong khai. CLERK_SECRET_KEY chi duoc dat o backend,
# tuyet doi khong dat vao bien frontend VITE_*/NEXT_PUBLIC_* va khong commit.
# Tai lieu: https://clerk.com/docs/guides/development/clerk-environment-variables
# [VERCEL: REQUIRED]
CLERK_PUBLISHABLE_KEY=""
# [VERCEL: REQUIRED, SENSITIVE]
CLERK_SECRET_KEY=""

# ----------------------------------------------------------------------------
# CLOUDFLARE R2 STORAGE (S3-COMPATIBLE)
# ----------------------------------------------------------------------------
# Production bat buoc du 4 bien R2 ben duoi. Local co the de trong ca 4 de dung
# storage tren dia; khong duoc chi dien mot phan vi app se fail-fast.
#
# Cach tao bucket va credentials:
#   1. Vao https://dash.cloudflare.com > Storage & databases > R2 > Overview.
#   2. Chon Create bucket; ten bucket la CLOUDFLARE_R2_BUCKET.
#   3. Tai R2 Overview, chon Manage trong API Tokens > Create Account API token
#      hoac Create User API token.
#   4. Chon Object Read & Write va gioi han `Apply to specific buckets only` cho
#      dung bucket Kindercare.
#   5. Sau khi tao, copy Access Key ID va Secret Access Key. Secret chi hien mot
#      lan, hay luu ngay vao password manager/Vercel Sensitive env.
#   6. Account ID nam trong S3 endpoint:
#      https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#
# Tai lieu: https://developers.cloudflare.com/r2/get-started/s3/
# [VERCEL: REQUIRED]
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_R2_BUCKET=""
# [VERCEL: REQUIRED, SENSITIVE]
CLOUDFLARE_R2_ACCESS_KEY=""
CLOUDFLARE_R2_SECRET_KEY=""

# Tuy chon. De trong neu bucket private; backend se tao presigned download URL.
# Neu file duoc phep public:
#   Cloudflare R2 > bucket > Settings > Public access > Custom Domains > Add.
# Dung custom domain production, vi du https://assets.example.com; khong co dau
# `/` cuoi. URL r2.dev chi nen dung de test, khong nen dung production.
# Tai lieu: https://developers.cloudflare.com/r2/buckets/public-buckets/
R2_PUBLIC_DOMAIN=""

# ----------------------------------------------------------------------------
# LOCAL FILE STORAGE (CHI DEVELOPMENT)
# ----------------------------------------------------------------------------
# Chi duoc dung khi ca 4 bien R2 de trong va NODE_ENV khong phai production.
# Filesystem cua Vercel khong phai persistent; production bat buoc dung R2.
UPLOAD_DIR="./uploads"

# ==============================================================================
# GITHUB ACTIONS SECRETS - KHONG PHAI APP ENV
# ==============================================================================
# De workflow `.github/workflows/deploy-production.yml` migrate va deploy tu dong:
#   GitHub repo > Settings > Environments > New environment: production
#   Them Environment secrets:
#
#   DATABASE_URL      Direct/migration-safe PostgreSQL URL. Day co the khac pooled
#                     DATABASE_URL cung ten duoc dat tren Vercel.
#   VERCEL_TOKEN      Vercel Account Settings > Tokens > Create token; scope token
#                     vao dung account/team chua project.
#   VERCEL_ORG_ID     Chay `npx vercel link`, sau do doc orgId trong
#                     `.vercel/project.json`.
#   VERCEL_PROJECT_ID Chay `npx vercel link`, sau do doc projectId trong
#                     `.vercel/project.json`.
#
# Khong them VERCEL_TOKEN vao `.env` cua app va khong commit `.vercel/project.json`.
# Sau khi tao database production, workflow se chay `npx prisma migrate deploy`
# truoc khi deploy commit da vuot qua Backend CI.
