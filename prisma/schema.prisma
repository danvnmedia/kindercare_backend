  weekStartDate DateTime @map("week_start_date") @db.Date
  title         String?
  days          Int[]    @default([1, 2, 3, 4, 5])
  mealSlots     String[] @default(["Breakfast", "Lunch", "Afternoon"]) @map("meal_slots")
