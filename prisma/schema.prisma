generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

model ParentRelationship {
  id          String  @id // e.g., "FATHER", "MOTHER", "GUARDIAN"
  name        String  @unique // e.g., "Bố", "Mẹ", "Người giám hộ"
  description String?

  studentParents StudentParent[]
}

model ClassRole {
  id          String  @id // Ví dụ: "HOMEROOM_TEACHER", "ASSISTANT"
  name        String  @unique // Ví dụ: "Giáo viên Chủ nhiệm", "Trợ giảng"
  description String?

  homeroomTeachers ClassHomeroomTeacher[]
}

model User {
  id          Int       @id @default(autoincrement())
  clerkUid    String?   @unique
  email       String?   @unique @db.Citext
  fullName    String?
  phoneNumber String?   @unique
  address     String?
  dateOfBirth DateTime?
  isActive    Boolean   @default(true)

  // Relations
  roles          Role[] // M:N
  teacherProfile TeacherProfile?
  studentProfile Student?

  // As a parent in StudentParent
  parentOf StudentParent[] @relation("ParentToStudent")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  permissions Json

  // Relations
  users User[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model TeacherProfile {
  id        Int       @id @default(autoincrement())
  startDate DateTime?

  // Relations
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @unique

  homerooms ClassHomeroomTeacher[]
  subjects  ClassSubjectTeacher[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model Student {
  id          Int       @id @default(autoincrement())
  fullName    String
  dateOfBirth DateTime?
  address     String?

  // Optional link to a login-capable user
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId Int?  @unique

  // Homeroom class
  class   Class? @relation(fields: [classId], references: [id], onDelete: SetNull)
  classId Int?

  // Parents
  parents StudentParent[] @relation("StudentToParent")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([classId])
}

model StudentParent {
  // Composite key to avoid duplicates
  student      Student @relation("StudentToParent", fields: [studentId], references: [id], onDelete: Cascade)
  studentId    Int
  parent       User    @relation("ParentToStudent", fields: [parentUserId], references: [id], onDelete: Cascade)
  parentUserId Int

  parentRelationship   ParentRelationship @relation(fields: [parentRelationshipId], references: [id])
  parentRelationshipId String

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@id([studentId, parentUserId])
  @@index([parentUserId])
}

model GradeLevel {
  id    Int    @id @default(autoincrement())
  name  String
  order Int

  classes Class[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([name])
  @@unique([order])
}

model Subject {
  id   Int    @id @default(autoincrement())
  name String @unique

  classes ClassSubjectTeacher[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model Class {
  id   Int    @id @default(autoincrement())
  name String

  gradeLevel   GradeLevel @relation(fields: [gradeLevelId], references: [id], onDelete: Restrict)
  gradeLevelId Int

  students         Student[]
  homeroomTeachers ClassHomeroomTeacher[]
  subjectTeachers  ClassSubjectTeacher[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // Đảm bảo không có trùng tên lớp trong cùng khối
  @@unique([gradeLevelId, name])
  @@index([gradeLevelId])
}

model ClassHomeroomTeacher {
  class            Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId          Int
  teacher          TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  teacherProfileId Int

  classRole   ClassRole @relation(fields: [classRoleId], references: [id])
  classRoleId String

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@id([classId, teacherProfileId])
  @@index([teacherProfileId])
}

model ClassSubjectTeacher {
  class            Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId          Int
  teacher          TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  teacherProfileId Int
  subject          Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId        Int

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@id([classId, teacherProfileId, subjectId])
  @@index([teacherProfileId])
  @@index([subjectId])
}
