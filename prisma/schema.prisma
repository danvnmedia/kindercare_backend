generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

// ==========================================
// SEQUENCE TABLES
// ==========================================

model StudentCodeSequence {
  year       Int      @id
  lastNumber Int      @default(0) @map("last_number")
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("student_code_sequence")
}

// ==========================================
// LOOKUP TABLES
// ==========================================

model GuardianRelationship {
  id          String  @id
  name        String  @unique
  description String?

  guardianStudents GuardianStudent[]

  @@map("guardian_relationship")
}

model Role {
  id          String  @id @db.Text
  name        String  @unique
  description String?
  permissions Json

  userRoles UserRole[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("role")
}

// ==========================================
// USER - AUTHENTICATION ONLY
// ==========================================

model User {
  id       String  @id @default(uuid()) @db.Uuid
  clerkUid String  @unique @map("clerk_uid")
  isActive Boolean @default(true) @map("is_active")

  // User can be either Guardian or Staff
  guardian Guardian?
  staff    Staff?

  // Authorization
  userRoles UserRole[]

  // Content Management
  posts             Post[]
  postHistories     PostHistory[]
  postStatusChanges PostHistoryStatus[]
  uploadedFiles     File[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([clerkUid])
  @@map("user")
}

model UserRole {
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id") @db.Uuid

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId String @map("role_id") @db.Text

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

// ==========================================
// PROFILE TYPES (Student, Staff, Guardian)
// ==========================================

model Student {
  id          String    @id @default(uuid()) @db.Uuid
  studentCode String    @unique @map("student_code")
  fullName    String    @map("full_name")
  email       String?   @db.Citext
  phoneNumber String?   @map("phone_number")
  address     String?
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  nickname    String?
  gender      String?
  status      String    @default("WAITING") // DROPPED, ACTIVE, GRADUATED, TRIAL, WAITING, DEFERRED
  isArchived  Boolean   @default(false) @map("is_archived")

  // Guardians relationship
  guardians GuardianStudent[]

  // Class & Enrollment
  enrollments   Enrollment[]
  attendances   StudentAttendance[]
  postAudiences PostAudience[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([email])
  @@index([phoneNumber])
  @@index([status])
  @@index([isArchived])
  @@map("student")
}

model Staff {
  id          String    @id @default(uuid()) @db.Uuid
  fullName    String    @map("full_name")
  email       String    @unique @db.Citext
  phoneNumber String    @unique @map("phone_number")
  address     String?
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  gender      String?
  startDate   DateTime? @map("start_date") @db.Date
  staffType   String    @default("TEACHER") @map("staff_type")
  isArchived  Boolean   @default(false) @map("is_archived")

  userId String? @unique @map("user_id") @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Staff class assignments
  classes ClassStaff[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([email])
  @@index([phoneNumber])
  @@index([userId])
  @@index([isArchived])
  @@index([staffType])
  @@map("staff")
}

model Guardian {
  id          String    @id @default(uuid()) @db.Uuid
  fullName    String    @map("full_name")
  email       String    @unique @db.Citext
  phoneNumber String    @unique @map("phone_number")
  address     String?
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  gender      String?
  occupation  String?
  workAddress String?   @map("work_address")
  isArchived  Boolean   @default(false) @map("is_archived")

  userId String? @unique @map("user_id") @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Spouse relationship
  spouse   Guardian? @relation("SpouseRelation", fields: [spouseId], references: [id], onDelete: SetNull)
  spouseId String?   @unique @map("spouse_id") @db.Uuid
  spouseOf Guardian? @relation("SpouseRelation")

  // Children relationship
  children GuardianStudent[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([email])
  @@index([phoneNumber])
  @@index([userId])
  @@index([spouseId])
  @@index([isArchived])
  @@map("guardian")
}

// ==========================================
// RELATIONSHIPS
// ==========================================

model GuardianStudent {
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String  @map("student_id") @db.Uuid

  guardian   Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  guardianId String   @map("guardian_id") @db.Uuid

  guardianRelationship   GuardianRelationship @relation(fields: [guardianRelationshipId], references: [id])
  guardianRelationshipId String               @map("guardian_relationship_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([studentId, guardianId])
  @@index([guardianId])
  @@index([guardianRelationshipId])
  @@map("guardian_student")
}

// ==========================================
// CLASS & GRADE LEVEL
// ==========================================

model GradeLevel {
  id    String @id @default(uuid()) @db.Uuid
  name  String @unique
  order Int    @unique

  classes       Class[]
  postAudiences PostAudience[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("grade_level")
}

model Subject {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  classes ClassStaff[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("subject")
}

model SchoolYear {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  status    Boolean  @default(false)

  classes Class[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status])
  @@map("school_year")
}

model Class {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String?

  gradeLevel   GradeLevel @relation(fields: [gradeLevelId], references: [id], onDelete: Restrict)
  gradeLevelId String     @map("grade_level_id") @db.Uuid
  schoolYear   SchoolYear @relation(fields: [schoolYearId], references: [id], onDelete: Restrict)
  schoolYearId String     @map("school_year_id") @db.Uuid

  staff         ClassStaff[]
  enrollments   Enrollment[]
  attendances   StudentAttendance[]
  postAudiences PostAudience[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([schoolYearId, gradeLevelId, name])
  @@index([gradeLevelId])
  @@index([schoolYearId])
  @@map("class")
}

model ClassStaff {
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId   String  @map("class_id") @db.Uuid
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId   String  @map("staff_id") @db.Uuid
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId String  @map("subject_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([classId, staffId, subjectId])
  @@index([staffId])
  @@index([subjectId])
  @@map("class_staff")
}

// ==========================================
// ENROLLMENT MANAGEMENT
// ==========================================

model Enrollment {
  id             String   @id @default(uuid()) @db.Uuid
  classId        String   @map("class_id") @db.Uuid
  studentId      String   @map("student_id") @db.Uuid
  enrollmentDate DateTime @map("enrollment_date") @db.Date
  note           String?

  class   Class   @relation(fields: [classId], references: [id], onDelete: Restrict)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([studentId, classId, enrollmentDate])
  @@index([classId])
  @@index([studentId])
  @@index([enrollmentDate])
  @@map("enrollment")
}

// ==========================================
// ATTENDANCE TRACKING
// ==========================================

model StudentAttendance {
  id         String    @id @default(uuid()) @db.Uuid
  studentId  String    @map("student_id") @db.Uuid
  classId    String    @map("class_id") @db.Uuid
  date       DateTime  @db.Date
  checkinAt  DateTime? @map("checkin_at") @db.Timestamptz(6)
  checkoutAt DateTime? @map("checkout_at") @db.Timestamptz(6)
  status     String    @default("PRESENT")
  reason     String?
  note       String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([studentId, date])
  @@index([classId])
  @@index([date])
  @@index([status])
  @@map("student_attendance")
}

// ==========================================
// POST & CONTENT MANAGEMENT
// ==========================================

model Post {
  id        String    @id @default(uuid()) @db.Uuid
  authorId  String    @map("author_id") @db.Uuid
  type      String
  title     String
  content   String?   @db.Text
  status    String    @default("DRAFT")
  publishAt DateTime? @map("publish_at") @db.Timestamptz(6)

  author User @relation(fields: [authorId], references: [id], onDelete: Restrict)

  history     PostHistory[]
  statusLog   PostHistoryStatus[]
  audiences   PostAudience[]
  attachments Attachment[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([authorId])
  @@index([status])
  @@index([type])
  @@index([publishAt])
  @@index([createdAt])
  @@map("post")
}

model PostHistory {
  id        String    @id @default(uuid()) @db.Uuid
  postId    String    @map("post_id") @db.Uuid
  authorId  String    @map("author_id") @db.Uuid
  audience  String?
  type      String
  title     String
  content   String?   @db.Text
  status    String
  publishAt DateTime? @map("publish_at") @db.Timestamptz(6)

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([postId])
  @@index([authorId])
  @@index([createdAt])
  @@map("post_history")
}

model PostHistoryStatus {
  id      String  @id @default(uuid()) @db.Uuid
  postId  String  @map("post_id") @db.Uuid
  userId  String  @map("user_id") @db.Uuid
  status  String
  comment String? @db.Text

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([postId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("post_history_status")
}

model PostAudience {
  id           String  @id @default(uuid()) @db.Uuid
  type         String
  postId       String  @map("post_id") @db.Uuid
  classId      String? @map("class_id") @db.Uuid
  studentId    String? @map("student_id") @db.Uuid
  gradeLevelId String? @map("grade_level_id") @db.Uuid

  post       Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  class      Class?      @relation(fields: [classId], references: [id], onDelete: Cascade)
  student    Student?    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gradeLevel GradeLevel? @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([classId])
  @@index([studentId])
  @@index([gradeLevelId])
  @@index([type])
  @@map("post_audience")
}

// ==========================================
// FILE & ATTACHMENT MANAGEMENT
// ==========================================

model File {
  id         String @id @default(uuid()) @db.Uuid
  key        String
  filename   String @map("filename")
  mimeType   String @map("mime_type")
  size       BigInt
  status     String @default("PENDING")
  uploadedBy String @map("uploaded_by") @db.Uuid

  uploader    User         @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)
  attachments Attachment[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([uploadedBy])
  @@index([status])
  @@index([createdAt])
  @@map("file")
}

model Attachment {
  id      String  @id @default(uuid()) @db.Uuid
  postId  String  @map("post_id") @db.Uuid
  fileId  String  @map("file_id") @db.Uuid
  comment String? @db.Text
  order   Int     @default(0)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  file File @relation(fields: [fileId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([postId, order])
  @@index([postId])
  @@index([fileId])
  @@map("attachment")
}
