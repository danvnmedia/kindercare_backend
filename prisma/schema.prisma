  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  changedBy User @relation("PostStatusChanges", fields: [changedById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([postId])
  @@index([changedById])
  @@index([newStatus])
  @@index([createdAt])
  @@map("post_history_status")
}

model PostAudience {
