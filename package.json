{
  "name": "kindercare-backend",
  "version": "1.0.0",
  "description": "Kindercare multi-campus school management API",
  "author": "DHA Enterprise",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DHA-Enterprise/kindercare_backend.git"
  },
  "bugs": {
    "url": "https://github.com/DHA-Enterprise/kindercare_backend/issues"
  },
  "homepage": "https://github.com/DHA-Enterprise/kindercare_backend#readme",
  "keywords": [
    "kindercare",
    "school-management",
    "multi-campus",
    "nestjs",
    "clean-architecture",
    "typescript",
    "prisma",
    "docker",
    "standard-response",
    "pagination",
    "filtering",
    "sorting"
  ],
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "clerk:get-token": "ts-node -r tsconfig-paths/register scripts/get-clerk-token.ts",
    "cli:create-admin": "ts-node -r tsconfig-paths/register src/cli/create-admin.ts",
    "cli:list-admins": "ts-node -r tsconfig-paths/register src/cli/create-admin.ts list",
    "cli:delete-admin": "ts-node -r tsconfig-paths/register src/cli/create-admin.ts delete",
    "export:audit-actions": "ts-node -r tsconfig-paths/register src/cli/export-audit-actions.ts",
    "seed:health-center": "ts-node -r tsconfig-paths/register ./prisma/seeds/seed-health-center.ts",
    "seed:students": "ts-node -r tsconfig-paths/register ./prisma/seeds/seed-students.ts",
    "seed:guardians": "ts-node -r tsconfig-paths/register ./prisma/seeds/seed-guardians.ts",
    "seed:dev-data": "ts-node -r tsconfig-paths/register ./prisma/seeds/seed-dev-data.ts",
    "seed:provision-guardian-clerk": "node --env-file=.env.local -r ts-node/register -r tsconfig-paths/register ./src/cli/provision-guardian-clerk.ts",
    "seed:verify-dev-data": "ts-node -r tsconfig-paths/register ./prisma/seeds/verify-dev-data.ts",
    "clerk:wipe-all-users": "node --env-file=.env.local -r ts-node/register -r tsconfig-paths/register ./src/cli/wipe-clerk-users.ts"
  },
  "dependencies": {
    "@clerk/backend": "^2.22.0",
    "@nestjs/bull": "^11.0.3",
    "@nestjs/bullmq": "^11.0.3",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.0.0",
    "bull": "^4.16.5",
    "bullmq": "^5.58.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "crypto": "^1.0.1",
    "ioredis": "^5.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "prisma": "^6.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.49.0"
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
