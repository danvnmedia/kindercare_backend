// Database schema in DBML format
// Updated: January 05, 2026
// Architecture: Single Instance with Federated Campus Isolation
// Strategy: Global Identity (User), Everything else Scoped to Campus (including Guardians)

// ==========================================
// INFRASTRUCTURE (THE ROOT)
// ==========================================

Table campus {
  id uuid [pk]
  name text // Ex: "Downtown Campus"
  address text
  phone_number text
  is_active boolean [default: true]
  created_at timestamptz
  updated_at timestamptz
}

// ==========================================
// ACCESS CONTROL (RBAC)
// ==========================================

// 1. Permissions (Static/Code-based - Global)
Table permission {
  id text [pk] 
  module text 
  description text
  created_at timestamptz
}

// 2. Roles (Configurable PER CAMPUS)
Table role {
  id uuid [pk]
  campus_id uuid [null] 
  name text 
  description text
  is_system_default boolean [default: false]
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (campus_id, name) [unique] 
  }
}
Ref: role.campus_id > campus.id

// 3. Mapping Roles to Permissions
Table role_permission {
  role_id uuid
  permission_id text
  created_at timestamptz

  indexes {
    (role_id, permission_id) [pk]
  }
}
Ref: role_permission.role_id > role.id
Ref: role_permission.permission_id > permission.id

// ==========================================
// USER & IDENTITY (GLOBAL)
// ==========================================

Table user {
  id uuid [pk]
  clerk_uid text [unique] // Identity Provider ID
  is_active boolean
  created_at timestamptz
  updated_at timestamptz
}

// 4. Assigning Roles to Users (Scoped)
Table user_roles {
  user_id uuid
  role_id uuid 
  campus_id uuid [null] 
  assigned_at timestamptz

  indexes {
    (user_id, role_id, campus_id) [pk]
    campus_id
  }
}
Ref: user_roles.user_id > user.id
Ref: user_roles.role_id > role.id
Ref: user_roles.campus_id > campus.id

// ==========================================
// STAFF CONFIGURATION (PER CAMPUS)
// ==========================================

Table staff_type {
  id uuid [pk]
  campus_id uuid
  name text 
  description text
  default_role_id uuid 
  is_active boolean
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (campus_id, name) [unique]
  }
}
Ref: staff_type.campus_id > campus.id
Ref: staff_type.default_role_id > role.id

// ==========================================
// PROFILES (ALL CAMPUS SCOPED)
// ==========================================

Table staff {
  id uuid [pk]
  campus_id uuid
  user_id uuid 
  staff_type_id uuid 
  full_name text
  email citext 
  phone_number text 
  address text
  date_of_birth date
  gender text
  start_date date
  is_archived boolean
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (campus_id, user_id) [unique] // One profile per user per campus
    (campus_id, email) [unique]
    (campus_id, phone_number) [unique]
    staff_type_id
    is_archived
  }
}
Ref: staff.user_id > user.id
Ref: staff.staff_type_id > staff_type.id
Ref: staff.campus_id > campus.id

Table student {
  id uuid [pk]
  campus_id uuid
  student_code text 
  full_name text
  email citext
  phone_number text
  address text
  date_of_birth date
  nickname text
  gender text
  status text 
  is_archived boolean
  created_at timestamptz
  updated_at timestamptz
  
  indexes {
    (campus_id, student_code) [unique]
    (campus_id, email)
    (campus_id, phone_number)
    status
    is_archived
  }
}
Ref: student.campus_id > campus.id

// CHANGED: Guardians are now Campus-Specific
Table guardian {
  id uuid [pk]
  campus_id uuid // <--- NEW SCOPE
  user_id uuid 
  full_name text
  email citext
  phone_number text
  address text
  date_of_birth date
  gender text
  occupation text
  work_address text
  is_archived boolean
  created_at timestamptz
  updated_at timestamptz
  
  indexes {
    (campus_id, user_id) [unique]   // Unique User per Campus
    (campus_id, email) [unique]     // Email unique per Campus (not global)
    (campus_id, phone_number) [unique]
    is_archived
  }
}
Ref: guardian.campus_id > campus.id
Ref: guardian.user_id > user.id

// ==========================================
// RELATIONSHIPS / LOOKUPS
// ==========================================

// Relationship types remain global (e.g. "Father" is universal)
Table guardian_relationship {
  id text [pk] 
  name text [unique]
  description text
}

Table guardian_student {
  student_id uuid
  guardian_id uuid
  guardian_relationship_id text
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (student_id, guardian_id) [pk]
    guardian_id
    guardian_relationship_id
  }
}
Ref: guardian_student.student_id > student.id
Ref: guardian_student.guardian_id > guardian.id
Ref: guardian_student.guardian_relationship_id > guardian_relationship.id

// ==========================================
// CLASS & ACADEMIC (PER CAMPUS)
// ==========================================

Table grade_level {
  id uuid [pk]
  campus_id uuid
  name text 
  order int 
  is_archived boolean
  created_at timestamptz
  updated_at timestamptz
  
  indexes {
    (campus_id, name) [unique]
    (campus_id, order) [unique]
    is_archived
  }
}
Ref: grade_level.campus_id > campus.id

Table subject {
  id uuid [pk]
  campus_id uuid
  name text 
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (campus_id, name) [unique]
  }
}
Ref: subject.campus_id > campus.id

Table school_year {
  id uuid [pk]
  campus_id uuid
  name text 
  start_date date
  end_date date
  is_archived boolean
  created_at timestamptz
  updated_at timestamptz
  
  indexes {
    (campus_id, name) [unique]
    is_archived
  }
}
Ref: school_year.campus_id > campus.id

Table class {
  id uuid [pk]
  campus_id uuid
  name text
  description text
  grade_level_id uuid
  school_year_id uuid
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (campus_id, school_year_id, grade_level_id, name) [unique]
    grade_level_id
    school_year_id
  }
}
Ref: class.grade_level_id > grade_level.id
Ref: class.school_year_id > school_year.id
Ref: class.campus_id > campus.id

Table class_staff {
  class_id uuid
  staff_id uuid
  subject_id uuid
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (class_id, staff_id, subject_id) [pk]
    staff_id
    subject_id
  }
}
Ref: class_staff.class_id > class.id
Ref: class_staff.staff_id > staff.id
Ref: class_staff.subject_id > subject.id

Table enrollment {
  id uuid [pk]
  class_id uuid
  student_id uuid
  enrollment_date date
  note text
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (student_id, class_id, enrollment_date) [unique]
    class_id
    student_id
    enrollment_date
  }
}
Ref: enrollment.class_id > class.id
Ref: enrollment.student_id > student.id

// ==========================================
// ATTENDANCE (PER CAMPUS)
// ==========================================

Table student_attendance {
  id uuid [pk]
  campus_id uuid 
  student_id uuid
  class_id uuid
  date date
  checkin_at timestamptz [null]
  checkout_at timestamptz [null]
  status text
  reason text [null]
  note text [null]
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (student_id, date) [unique]
    class_id
    campus_id
    date
    status
  }
}
Ref: student_attendance.student_id > student.id
Ref: student_attendance.class_id > class.id
Ref: student_attendance.campus_id > campus.id

// ==========================================
// POST & CONTENT (PER CAMPUS)
// ==========================================

Table post {
  id uuid [pk]
  campus_id uuid 
  author_id uuid
  title text
  content text
  status text 
  publish_at timestamptz
  created_at timestamptz
  updated_at timestamptz

  indexes {
    campus_id
    author_id
    status
    publish_at
    created_at
  }
}
Ref: post.author_id > user.id
Ref: post.campus_id > campus.id

Table post_history {
  id uuid [pk]
  post_id uuid
  author_id uuid
  audience text
  title text
  content text
  status text
  publish_at timestamptz
  created_at timestamptz
  updated_at timestamptz

  indexes {
    post_id
    author_id
    created_at
  }
}
Ref: post_history.post_id > post.id
Ref: post_history.author_id > user.id

Table post_history_status {
  id uuid [pk]
  post_id uuid
  user_id uuid 
  status text
  comment text
  created_at timestamptz
  updated_at timestamptz

  indexes {
    post_id
    user_id
    status
    created_at
  }
}
Ref: post_history_status.post_id > post.id
Ref: post_history_status.user_id > user.id

Table post_audience {
  id uuid [pk]
  type text 
  post_id uuid
  campus_id uuid 
  class_id uuid [null]
  student_id uuid [null]
  grade_level_id uuid [null]
  
  indexes {
    post_id
    campus_id
    class_id
    student_id
    grade_level_id
    type
  }
}
Ref: post_audience.post_id > post.id
Ref: post_audience.campus_id > campus.id
Ref: post_audience.class_id > class.id
Ref: post_audience.student_id > student.id
Ref: post_audience.grade_level_id > grade_level.id

// ==========================================
// FILES (PER CAMPUS)
// ==========================================

Table file {
  id uuid [pk]
  campus_id uuid 
  key text
  filename text
  mime_type text
  size bigint
  status text 
  uploaded_by uuid
  created_at timestamptz
  updated_at timestamptz

  indexes {
    campus_id
    uploaded_by
    status
    created_at
  }
}
Ref: file.uploaded_by > user.id
Ref: file.campus_id > campus.id

Table attachment {
  id uuid [pk]
  post_id uuid
  file_id uuid
  comment text
  order int
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (post_id, order) [unique]
    post_id
    file_id
  }
}
Ref: attachment.post_id > post.id
Ref: attachment.file_id > file.id

// ==========================================
// UTILITY
// ==========================================

Table student_code_sequence {
  campus_id uuid [pk]
  year int [pk]
  last_number int
  updated_at timestamptz
}
Ref: student_code_sequence.campus_id > campus.id
