// Database schema in DBML format (snake_case tables/columns)
// Updated: December 18, 2025

// ==========================================
// SEQUENCE TABLES
// ==========================================

Table student_code_sequence {
  year int [pk]
  last_number int
  updated_at timestamptz
}

// ==========================================
// LOOKUP TABLES
// ==========================================

Table guardian_relationship {
  id text [pk]
  name text [unique]
  description text
}

Table role {
  id text [pk]
  name text [unique]
  description text
  permissions jsonb
  created_at timestamptz
  updated_at timestamptz
}

// ==========================================
// USER - AUTHENTICATION ONLY
// ==========================================

Table user {
  id uuid [pk]
  clerk_uid text [unique]
  is_active boolean
  created_at timestamptz
  updated_at timestamptz
}

Table user_roles {
  user_id uuid
  role_id text

  indexes {
    (user_id, role_id) [pk]
    role_id
  }
}
Ref: user_roles.user_id > user.id
Ref: user_roles.role_id > role.id

// ==========================================
// PROFILE TYPES (Student, Staff, Guardian)
// ==========================================

Table student {
  id uuid [pk]
  student_code text [unique] // Ex: AN564GD5
  full_name text
  email citext
  phone_number text
  address text
  date_of_birth date
  nickname text
  gender text
  status text // DROPPED, ACTIVE, GRADUATED, TRIAL, WAITING, DEFERRED
  is_archived boolean
  created_at timestamptz
  updated_at timestamptz

  indexes {
    email
    phone_number
    status
    is_archived
  }
}

Table staff {
  id uuid [pk]
  full_name text
  email citext [unique]
  phone_number text [unique]
  address text
  date_of_birth date
  gender text
  start_date date
  staff_type text // TEACHER, ADMIN, etc.
  is_archived boolean
  user_id uuid [unique]
  created_at timestamptz
  updated_at timestamptz

  indexes {
    email
    phone_number
    user_id
    is_archived
    staff_type
  }
}
Ref: staff.user_id > user.id

Table guardian {
  id uuid [pk]
  full_name text
  email citext [unique]
  phone_number text [unique]
  address text
  date_of_birth date
  gender text
  occupation text
  work_address text
  is_archived boolean
  user_id uuid [unique]
  spouse_id uuid [unique]
  created_at timestamptz
  updated_at timestamptz

  indexes {
    email
    phone_number
    user_id
    spouse_id
    is_archived
  }
}
Ref: guardian.user_id > user.id
Ref: guardian.spouse_id > guardian.id

// ==========================================
// RELATIONSHIPS
// ==========================================

Table guardian_student {
  student_id uuid
  guardian_id uuid
  guardian_relationship_id text
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (student_id, guardian_id) [pk]
    guardian_id
    guardian_relationship_id
  }
}
Ref: guardian_student.student_id > student.id
Ref: guardian_student.guardian_id > guardian.id
Ref: guardian_student.guardian_relationship_id > guardian_relationship.id

// ==========================================
// CLASS & GRADE LEVEL
// ==========================================

Table grade_level {
  id uuid [pk]
  name text [unique]
  order int [unique]
  created_at timestamptz
  updated_at timestamptz
}

Table subject {
  id uuid [pk]
  name text [unique]
  created_at timestamptz
  updated_at timestamptz
}

Table school_year {
  id uuid [pk]
  name text [unique]
  start_date date
  end_date date
  status boolean // active or not
  created_at timestamptz
  updated_at timestamptz

  indexes {
    status
  }
}

Table class {
  id uuid [pk]
  name text
  description text
  grade_level_id uuid
  school_year_id uuid
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (school_year_id, grade_level_id, name) [unique]
    grade_level_id
    school_year_id
  }
}
Ref: class.grade_level_id > grade_level.id
Ref: class.school_year_id > school_year.id

Table class_staff {
  class_id uuid
  staff_id uuid
  subject_id uuid
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (class_id, staff_id, subject_id) [pk]
    staff_id
    subject_id
  }
}
Ref: class_staff.class_id > class.id
Ref: class_staff.staff_id > staff.id
Ref: class_staff.subject_id > subject.id

// ==========================================
// ENROLLMENT MANAGEMENT
// ==========================================

Table enrollment {
  id uuid [pk]
  class_id uuid
  student_id uuid
  enrollment_date date
  note text
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (student_id, class_id, enrollment_date) [unique]
    class_id
    student_id
    enrollment_date
  }
}
Ref: enrollment.class_id > class.id
Ref: enrollment.student_id > student.id

// ==========================================
// ATTENDANCE TRACKING
// ==========================================

Table student_attendance {
  id uuid [pk]
  student_id uuid
  class_id uuid
  date date
  checkin_at timestamptz [null]
  checkout_at timestamptz [null]
  status text // PRESENT, ABSENT, EXCUSED, etc.
  reason text [null]
  note text [null]
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (student_id, date) [unique]
    class_id
    date
    status
  }
}
Ref: student_attendance.student_id > student.id
Ref: student_attendance.class_id > class.id

// ==========================================
// POST & CONTENT MANAGEMENT
// ==========================================

Table post {
  id uuid [pk]
  author_id uuid
  type text // post, album
  title text
  content text
  status text // DRAFT, PENDING_REVIEW, APPROVED, REJECTED, PUBLISHED
  publish_at timestamptz
  created_at timestamptz
  updated_at timestamptz

  indexes {
    author_id
    status
    type
    publish_at
    created_at
  }
}
Ref: post.author_id > user.id

Table post_history {
  id uuid [pk]
  post_id uuid
  author_id uuid
  audience text
  type text
  title text
  content text
  status text
  publish_at timestamptz
  created_at timestamptz
  updated_at timestamptz

  indexes {
    post_id
    author_id
    created_at
  }
}
Ref: post_history.post_id > post.id
Ref: post_history.author_id > user.id

Table post_history_status {
  id uuid [pk]
  post_id uuid
  user_id uuid // person who made the change
  status text
  comment text
  created_at timestamptz
  updated_at timestamptz

  indexes {
    post_id
    user_id
    status
    created_at
  }
}
Ref: post_history_status.post_id > post.id
Ref: post_history_status.user_id > user.id

Table post_audience {
  id uuid [pk]
  type text // CLASS, STUDENT, GRADE_LEVEL
  post_id uuid
  class_id uuid [null]
  student_id uuid [null]
  grade_level_id uuid [null]

  indexes {
    post_id
    class_id
    student_id
    grade_level_id
    type
  }
}
Ref: post_audience.post_id > post.id
Ref: post_audience.class_id > class.id
Ref: post_audience.student_id > student.id
Ref: post_audience.grade_level_id > grade_level.id

// ==========================================
// FILE & ATTACHMENT MANAGEMENT
// ==========================================

Table file {
  id uuid [pk]
  key text
  filename text
  mime_type text
  size bigint
  status text // PENDING, CONFIRMED, DELETED
  uploaded_by uuid
  created_at timestamptz
  updated_at timestamptz

  indexes {
    uploaded_by
    status
    created_at
  }
}
Ref: file.uploaded_by > user.id

Table attachment {
  id uuid [pk]
  post_id uuid
  file_id uuid
  comment text
  order int
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (post_id, order) [unique]
    post_id
    file_id
  }
}
Ref: attachment.post_id > post.id
Ref: attachment.file_id > file.id
