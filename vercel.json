{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  },
  "crons": [
    {
      "path": "/api/internal/cron/medication-lifecycle",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/internal/cron/cleanup-hourly",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/internal/cron/cleanup-daily",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/internal/cron/school-year-lifecycle-expiration",
      "schedule": "15 1 * * *"
    }
  ]
}
